# ══════════════════════════════════════════════════════════════
# AlphaForge — Port Configuration
# ══════════════════════════════════════════════════════════════
# Single source of truth for all service ports.
# Referenced by backend/.env, frontend/.env, and docker-compose.
#
# To override: copy this file and source it, or set vars in your shell.
# ══════════════════════════════════════════════════════════════

# ── Application Services ─────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Data Stores ──────────────────────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── Background Workers ───────────────────────────────────────
# Celery uses Redis as broker (no separate port needed)
# Flower dashboard (Celery monitoring) — uncomment if used:
# FLOWER_PORT=5555
