# ══════════════════════════════════════════════════════════════
# AlphaForge — Root Environment Configuration
# ══════════════════════════════════════════════════════════════
# Tracked file with non-secret defaults.
# Credentials live in .env.cred.local (gitignored).
# Service ports live in .env.port.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=AlphaForge
APP_ENV=development                       # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=alphaforge.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Database ─────────────────────────────────────────────────
# Credentials (POSTGRES_USER, POSTGRES_PASSWORD) are in .env.cred.local
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge@localhost:${POSTGRES_PORT:-5432}/alphaforge

# ── Auth / JWT ───────────────────────────────────────────────
# JWT_SECRET_KEY is in .env.cred.local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:${FRONTEND_PORT:-3000}"]
