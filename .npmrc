# AlphaForge — pnpm / npm configuration
# Ensures consistent behavior across all contributors

# Use exact versions when adding dependencies (no ^ or ~)
save-exact=true

# Hoist node_modules for compatibility with tools that don't support pnpm symlinks
# (Next.js, some ESLint plugins, etc.)
shamefully-hoist=true

# Strict peer dependency resolution — fail on unmet peer deps
strict-peer-dependencies=false

# Use the lockfile strictly — don't update it during install
frozen-lockfile=false

# Prefer offline packages when available
prefer-offline=true

# Engine strict — enforce engines field in package.json
engine-strict=true
