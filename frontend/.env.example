# ══════════════════════════════════════════════════════════════
# AlphaForge Frontend — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy to .env.local (Next.js auto-loads this file).
# Only NEXT_PUBLIC_ vars are exposed to the browser bundle.
# See .env.port at repo root for port definitions.
# ══════════════════════════════════════════════════════════════

# ── Public (exposed to browser) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AlphaForge
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Server-only (SSR / API routes) ──────────────────────────
# Internal backend URL (used by Next.js server-side requests, e.g. inside Docker)
INTERNAL_API_URL=http://localhost:8000
