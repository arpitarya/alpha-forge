# AlphaForge Backend Configuration
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────
APP_NAME=AlphaForge
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/api/v1

# ── Server ───────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge@localhost:5432/alphaforge

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Indian Broker: Zerodha Kite ──────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Indian Broker: Angel One ─────────────────────
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Market Data ──────────────────────────────────
NSE_DATA_URL=https://www.nseindia.com
BSE_DATA_URL=https://www.bseindia.com

# ── Celery ───────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
