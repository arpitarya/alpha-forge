# ══════════════════════════════════════════════════════════════
# AlphaForge — Credentials (NEVER COMMIT THIS FILE)
# ══════════════════════════════════════════════════════════════
# Copy to .env.cred and fill in real values.
# This file holds secrets only — config lives in .env, ports in .env.port.
# ══════════════════════════════════════════════════════════════

# ── App Secrets ──────────────────────────────────────────────
SECRET_KEY=
JWT_SECRET_KEY=

# ── Database Credentials ─────────────────────────────────────
POSTGRES_USER=alphaforge
POSTGRES_PASSWORD=

# ── AI / LLM ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Indian Broker: Zerodha Kite (web-login flow) ─────────────
# Used by the Kite + Coin sources (they share the session).
ZERODHA_USER_ID=
ZERODHA_APP_CODE=
ZERODHA_TOTP_SECRET=

# Legacy paid-API keys (Kite Connect) — keep blank unless you've subscribed.
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Indian Broker: Groww (reverse-engineered web API) ────────
GROWW_USER_ID=
GROWW_PASSWORD=
GROWW_TOTP_SECRET=

# ── Indian Broker: Angel One (SmartAPI) ──────────────────────
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Aliases used by older code paths.
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Indian Broker: Wint Wealth (OTP-bound) ───────────────────
WINT_USER_ID=
WINT_OTP_CHANNEL=sms

# Optional: override default broker session cache directory.
# BROKER_CACHE_DIR=.cache/brokers
