# ══════════════════════════════════════════════════════════════
# AlphaForge Backend — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Credentials go in .env.cred — see ../.env.cred.example
# Service ports are defined in ../.env.port
# Never commit .env or .env.cred.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=AlphaForge
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# Credentials (POSTGRES_USER, POSTGRES_PASSWORD) are in .env.cred
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge@localhost:5432/alphaforge

# ── Auth / JWT ───────────────────────────────────────────────
# JWT_SECRET_KEY is in .env.cred
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── LLM Gateway (free multi-provider) ────────────────────────
# Get free keys: aistudio.google.com, console.groq.com, huggingface.co, openrouter.ai
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Broker keys are in .env.cred ─────────────────────────────
# KITE_API_KEY, KITE_API_SECRET, ANGEL_API_KEY, etc.

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs                              # Directory for log files (relative to backend/)
LOG_FILE=alphaforge.log                   # Log filename
LOG_MAX_BYTES=10485760                    # Max log file size before rotation (10 MB)
LOG_BACKUP_COUNT=5                        # Number of rotated log files to keep

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]    # Must match FRONTEND_PORT in .env.port
