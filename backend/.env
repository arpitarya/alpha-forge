# ══════════════════════════════════════════════════════════════
# AlphaForge Backend — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Credentials go in .env.cred — see ../.env.cred.example
# Service ports are defined in ../.env.port
# Never commit .env or .env.cred.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=AlphaForge
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────
# Credentials (POSTGRES_USER, POSTGRES_PASSWORD) are in .env.cred
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge@localhost:5432/alphaforge

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────────────────
# SECRET_KEY and JWT_SECRET_KEY are in .env.cred
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ────────────────────────────────────────────────
# OPENAI_API_KEY is in .env.cred
OPENAI_MODEL=gpt-4o

# ── LLM Gateway (free multi-provider) ────────────────────────
# Get free keys: aistudio.google.com, console.groq.com, huggingface.co, openrouter.ai
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Broker keys are in .env.cred ─────────────────────────────
# KITE_API_KEY, KITE_API_SECRET, ANGEL_API_KEY, etc.

# ── Market Data ──────────────────────────────────────────────
NSE_DATA_URL=https://www.nseindia.com
BSE_DATA_URL=https://www.bseindia.com
