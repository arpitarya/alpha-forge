{
  "$schema": "https://tr.designtokens.org/format/",
  "name": "Solar Terminal",
  "version": "0.1.0",

  "color": {
    "primary": {
      "$value": "#ff8f00",
      "$description": "Brand amber — CTAs, active indicators, Solar Orb glow"
    },
    "primary-light": {
      "$value": "#ffa44f",
      "$description": "Lighter amber for hover states and secondary accents"
    },
    "primary-dark": {
      "$value": "#cc7200",
      "$description": "Darker amber for pressed / active states"
    },

    "surface": {
      "lowest": { "$value": "#000000", "$description": "App background (pure black)" },
      "low": { "$value": "#0e0e0e", "$description": "Primary surface — panels, sidebars" },
      "default": { "$value": "#131313", "$description": "Card backgrounds" },
      "container": { "$value": "#1a1a1a", "$description": "Input backgrounds, hover fills" },
      "bright": { "$value": "#2c2c2c", "$description": "Elevated surfaces, tooltips" },
      "overlay": { "$value": "rgba(0, 0, 0, 0.6)", "$description": "Modal / dialog backdrop" }
    },

    "on-surface": {
      "default": { "$value": "#ffffff", "$description": "Primary text on dark surface" },
      "variant": { "$value": "#adaaaa", "$description": "Secondary text, labels" },
      "muted": { "$value": "#666666", "$description": "Disabled text, placeholders" },
      "faint": { "$value": "rgba(255, 255, 255, 0.3)", "$description": "Ghost text, subtle labels" }
    },

    "outline": {
      "default": { "$value": "#484847", "$description": "Standard borders and dividers" },
      "subtle": { "$value": "rgba(255, 255, 255, 0.05)", "$description": "Floating-shard borders (glassmorphism)" },
      "focus": { "$value": "#ff8f00", "$description": "Focus ring color" }
    },

    "semantic": {
      "green": { "$value": "#34d399", "$description": "Positive — profit, buy signals, price up" },
      "red": { "$value": "#f87171", "$description": "Negative — loss, sell signals, price down" },
      "orange": { "$value": "#f59e0b", "$description": "Warning — neutral signals, caution" },
      "purple": { "$value": "#a855f7", "$description": "AI — smart features, analysis badges" },
      "blue": { "$value": "#3b82f6", "$description": "Info — links, informational badges" }
    },

    "glass": {
      "bg": { "$value": "rgba(255, 255, 255, 0.03)", "$description": "Glassmorphic shard background" },
      "border": { "$value": "rgba(255, 255, 255, 0.05)", "$description": "Glassmorphic shard border" }
    }
  },

  "font": {
    "family": {
      "headline": { "$value": "'Space Grotesk', sans-serif", "$description": "Headlines and display text" },
      "body": { "$value": "'Space Grotesk', sans-serif", "$description": "Body text and UI labels" },
      "mono": { "$value": "'JetBrains Mono', 'SF Mono', 'Fira Code', ui-monospace, monospace", "$description": "Financial numbers, code" }
    },
    "weight": {
      "light": { "$value": 300 },
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 700 }
    },
    "size": {
      "display": { "$value": "2.25rem", "$description": "36px — hero text" },
      "headline": { "$value": "0.875rem", "$description": "14px — section headers (uppercase)" },
      "title": { "$value": "1.25rem", "$description": "20px — card titles" },
      "body": { "$value": "0.875rem", "$description": "14px — body text" },
      "label": { "$value": "0.625rem", "$description": "10px — input labels, meta" },
      "caption": { "$value": "0.625rem", "$description": "10px — timestamps, footnotes" },
      "mono-data": { "$value": "0.8125rem", "$description": "13px — financial numbers" }
    },
    "line-height": {
      "tight": { "$value": "1.1" },
      "normal": { "$value": "1.5" },
      "relaxed": { "$value": "1.7" }
    },
    "letter-spacing": {
      "tighter": { "$value": "-0.05em" },
      "normal": { "$value": "0em" },
      "wide": { "$value": "0.15em" },
      "wider": { "$value": "0.2em" },
      "widest": { "$value": "0.3em" }
    }
  },

  "spacing": {
    "0": { "$value": "0px" },
    "1": { "$value": "4px", "$description": "Tight — within components" },
    "2": { "$value": "8px", "$description": "Compact — between related items" },
    "3": { "$value": "12px", "$description": "Standard — panel padding" },
    "4": { "$value": "16px", "$description": "Comfortable — section spacing" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px", "$description": "Spacious — between major sections" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" },
    "24": { "$value": "96px" }
  },

  "radius": {
    "none": { "$value": "0px" },
    "sm": { "$value": "6px", "$description": "Buttons, inputs, tooltips" },
    "md": { "$value": "8px", "$description": "Cards, panels" },
    "lg": { "$value": "16px", "$description": "Larger panels" },
    "xl": { "$value": "24px", "$description": "Modals, sheets" },
    "2xl": { "$value": "2.5rem", "$description": "Solar Terminal shard cards" },
    "full": { "$value": "9999px", "$description": "Pill buttons, badges, avatars" }
  },

  "shadow": {
    "none": { "$value": "none" },
    "sm": { "$value": "0 1px 2px rgba(0, 0, 0, 0.5)" },
    "md": { "$value": "0 4px 12px rgba(0, 0, 0, 0.4)" },
    "lg": { "$value": "0 8px 24px rgba(0, 0, 0, 0.5)" },
    "glow-primary": { "$value": "0 0 40px rgba(255, 143, 0, 0.15)", "$description": "Ambient primary glow" },
    "glow-primary-lg": { "$value": "0 0 120px rgba(255, 143, 0, 0.4)", "$description": "Solar Orb outer glow" },
    "glow-green": { "$value": "0 0 12px rgba(52, 211, 153, 0.2)" },
    "glow-red": { "$value": "0 0 12px rgba(248, 113, 113, 0.2)" }
  },

  "blur": {
    "glass": { "$value": "40px", "$description": "Floating shard backdrop-filter" },
    "orb": { "$value": "2px", "$description": "Solar Orb filter blur" }
  },

  "animation": {
    "duration": {
      "instant": { "$value": "0ms" },
      "fast": { "$value": "150ms", "$description": "Hover transitions, focus rings" },
      "normal": { "$value": "300ms", "$description": "Expand/collapse, slide" },
      "slow": { "$value": "700ms", "$description": "Card hover scale transitions" },
      "pulse": { "$value": "8s", "$description": "Solar Orb glow pulse cycle" }
    },
    "easing": {
      "default": { "$value": "ease" },
      "in-out": { "$value": "ease-in-out" },
      "spring": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
    }
  },

  "layout": {
    "sidebar": {
      "collapsed": { "$value": "56px" },
      "expanded": { "$value": "200px" }
    },
    "header": {
      "height": { "$value": "48px" }
    },
    "content-gap": { "$value": "4px" },
    "breakpoint": {
      "sm": { "$value": "640px" },
      "md": { "$value": "768px" },
      "lg": { "$value": "1024px" },
      "xl": { "$value": "1280px" },
      "2xl": { "$value": "1536px" }
    }
  },

  "z-index": {
    "base": { "$value": 0 },
    "dropdown": { "$value": 10 },
    "sticky": { "$value": 20 },
    "header": { "$value": 30 },
    "sidebar": { "$value": 40 },
    "modal": { "$value": 50 },
    "tooltip": { "$value": 60 },
    "toast": { "$value": 70 }
  }
}
