{
  "name": "AlphaForge",
  "dockerComposeFile": "../infra/docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/app",
  "forwardPorts": [8000, 3000, 5432, 6379],
  "postCreateCommand": "cd /app/backend && pip install pdm && pdm install && cd /app/frontend && corepack enable && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/backend/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
