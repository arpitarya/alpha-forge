{
  "name": "@alphaforge/solar-orb-ui",
  "version": "0.1.0",
  "description": "Solar Terminal design system — UI components, tokens, and fonts for AlphaForge",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/styles.css",
    "./theme": "./src/styles/theme.css",
    "./src/styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "solar-terminal",
    "alphaforge",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alphaforge/alpha-forge",
    "directory": "packages/solar-orb-ui"
  }
}
