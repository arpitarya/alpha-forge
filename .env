# ══════════════════════════════════════════════════════════════
# AlphaForge — Root Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Credentials (API keys, passwords) go in .env.cred — see .env.cred.example
# Service ports are defined in .env.port
# Never commit .env or .env.cred files.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=AlphaForge
APP_ENV=development                       # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Ports (override .env.port defaults) ─────────────────────
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=alphaforge.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Database ─────────────────────────────────────────────────
# Credentials (POSTGRES_USER, POSTGRES_PASSWORD) are in .env.cred
POSTGRES_DB=alphaforge
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge@localhost:5432/alphaforge

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────────────────
# SECRET_KEY and JWT_SECRET_KEY are in .env.cred
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ────────────────────────────────────────────────
# OPENAI_API_KEY is in .env.cred
OPENAI_MODEL=gpt-4o

# ── Market Data ──────────────────────────────────────────────
NSE_DATA_URL=https://www.nseindia.com
BSE_DATA_URL=https://www.bseindia.com

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:${REDIS_PORT:-6379}/1
CELERY_RESULT_BACKEND=redis://localhost:${REDIS_PORT:-6379}/2

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:${FRONTEND_PORT:-3000}"]

# ── Frontend (public vars — prefixed with NEXT_PUBLIC_) ──────
NEXT_PUBLIC_API_URL=http://localhost:${BACKEND_PORT:-8000}
NEXT_PUBLIC_APP_NAME=AlphaForge
NEXT_PUBLIC_WS_URL=ws://localhost:${BACKEND_PORT:-8000}/ws
