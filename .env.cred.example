# ══════════════════════════════════════════════════════════════
# AlphaForge — Credentials TEMPLATE (this file IS tracked in git)
# ══════════════════════════════════════════════════════════════
# Real values go in .env.cred.local (gitignored). Copy this file:
#
#   cp .env.cred.example .env.cred.local   # then fill in real values
#
# .env.cred.local is loaded after .env.cred.example by env_loader and
# overrides any value here.
#
# DO NOT add real secrets to this file — it is committed.
# ══════════════════════════════════════════════════════════════

# ── App Secrets ──────────────────────────────────────────────
JWT_SECRET_KEY=

# ── Database Credentials ─────────────────────────────────────
POSTGRES_USER=alphaforge
POSTGRES_PASSWORD=

# ── Indian Broker: Zerodha Kite (manual CDP login) ───────────
# AlphaForge does NOT store your password or TOTP. You log in once
# inside Chrome (started with --remote-debugging-port=9299) and the
# backend reads the session cookie via CDP. Only your client ID is needed.
ZERODHA_USER_ID=

# Optional: how long to wait for manual login in attached Chrome (seconds).
# ZERODHA_LOGIN_CDP_WAIT=180

# Required: Fernet key for encrypting cached broker session tokens at rest.
# Generate once: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
BROKER_CACHE_KEY=

# Optional: override default broker session cache directory.
# BROKER_CACHE_DIR=.cache/brokers
# Optional: session TTL in seconds (default 23h).
# BROKER_SESSION_TTL=82800
# Optional: bind CDP to a specific loopback addr (default 127.0.0.1).
# BROKER_CDP_HOST=127.0.0.1
# Optional: override CDP port (default 9299).
# BROKER_CDP_PORT=9299

# Optional: where `just zerodha-dump` writes the daily holdings xlsx.
# PORTFOLIO_DUMP_DIR=~/.alphaforge/portfolio-dumps
